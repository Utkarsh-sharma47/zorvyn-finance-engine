# API
API_PORT=8000

# PostgreSQL (host ports when running Compose locally)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_only
POSTGRES_DB=nexus_finance
POSTGRES_PORT=5432

# SQLAlchemy (use Docker service hostnames from containers)
DATABASE_URL=postgresql+psycopg2://nexus:nexus_dev_only@db:5432/nexus_finance

# Redis
REDIS_PORT=6379
REDIS_URL=redis://cache:6379/0

# JWT (required; generate a long random string for production)
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: comma-separated browser origins (no wildcard when credentials are used)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
