# API
API_PORT=8000

# PostgreSQL (host ports when running compose locally)
POSTGRES_USER=zorvyn
POSTGRES_PASSWORD=zorvyn
POSTGRES_DB=zorvyn
POSTGRES_PORT=5432

# SQLAlchemy / SQLModel (use Docker Compose service names from inside containers)
DATABASE_URL=postgresql+psycopg2://zorvyn:zorvyn@db:5432/zorvyn

# Redis
REDIS_PORT=6379
REDIS_URL=redis://cache:6379/0

# JWT (used by app.core.security)
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
